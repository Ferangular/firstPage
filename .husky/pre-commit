#!/bin/sh

# Ejecutar lint y formateo siempre
npm run lint:fix

# Ejecutar tests solo si hay cambios en archivos TypeScript y si existen tests
if git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx)$'; then
  # Verificar si hay archivos de test
  if find src -name "*.spec.ts" -o -name "*.test.ts" | head -1 | grep -q .; then
    npm run test:ci || echo "Tests failed but continuing..." 
  fi
fi

# Ejecutar lint-staged siempre
npx lint-staged
